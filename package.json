{
  "name": "@ijideals/autokeys",
  "version": "0.4.1",
  "type": "module",
  "bin": {
    "autokeys": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "start": "node dist/cli/index.js"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.10",
    "jscodeshift": "^0.15.2",
    "recast": "^0.23.6",
    "slugify": "^1.6.6",
    "zod": "^3.24.1",
    "cosmiconfig": "^9.0.1",
    "pino": "^10.3.1",
    "colorette": "^2.0.20",
    "cli-progress": "^3.12.0",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@types/jscodeshift": "^0.11.11",
    "@types/node": "^22.19.17",
    "typescript": "^5.9.0",
    "vitest": "^4.1.5",
    "@types/cosmiconfig": "^6.0.3",
    "@types/cli-progress": "^3.11.6"
  },
  "engines": {
    "node": ">=18"
