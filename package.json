    "recast": "^0.23.6",
    "slugify": "^1.6.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jscodeshift": "^0.11.11",
    "@types/node": "^22.19.17",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=18"
  },
  "description": "IJIDeals Autokeys - Auto-generate keys and slugs",
  "repository": {
    "type": "git",
